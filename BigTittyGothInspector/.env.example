# Core Discord bot config
DISCORD_BOT_TOKEN=
GUILD_ID=
# Role ID or exact role name both work.
BTGO_ROLE_ID=
IBTC_ROLE_ID=
# Optional channel for periodic IBTC taunts; if empty bot falls back to system/first writable text channel.
IBTC_TAUNT_CHANNEL_ID=
# Approximate cadence in minutes for IBTC taunts.
IBTC_TAUNT_INTERVAL_MINUTES=60
COMMAND_PREFIX=!
TIMEZONE=America/New_York

# Daily winner settings (2-5 by default)
DAILY_MIN_WINNERS=2
DAILY_MAX_WINNERS=5
# 0-100 chance for !inspect to succeed (default 10 = 10%)
INSPECT_SUCCESS_PERCENT=10

# Comma-separated user IDs who can always use !reshuffle
RESHUFFLE_USER_IDS=

# Comma-separated user IDs with forced outcomes for both !inspect and daily shuffle.
ALWAYS_PASS_USER_IDS=
NEVER_PASS_USER_IDS=

# AI response toggle and model config
ENABLE_AI_RESPONSES=false
# 0-100 chance to use AI when ENABLE_AI_RESPONSES=true
AI_RESPONSE_PERCENT=100
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
AI_SYSTEM_PROMPT=You are a bold, confident goth inspector persona. Keep replies short, playful, dominant, and Discord-safe.

# Response pools use || as the separator between canned options.
HELP_RESPONSES=Listen up, simps. Here is how this inspection works.||Eyes up, simps. Here are your commands.||The inspector has spoken. Read the command list and obey.
INSPECT_SUCCESS_RESPONSES=Be careful of the simps {target}. You are a hell of a big titty goth.||Inspection passed. {target} nice tits.||UwU! look at those! {target} is the real thing.
INSPECT_FAIL_RESPONSES=Not today, simp. {target} failed inspection.||Denied. {target} stays unworthy for now.||You call those tits? {target} gets nothing today.
INSPECT_COOLDOWN_RESPONSES=Easy, simp. You already used your inspection for today.||You are a nincompoop.||Loser. Your daily inspection, I'm not looking at those tiny things again.
RESHUFFLE_DENIED_RESPONSES=Sit down, simp. You do not have reshuffle authority.||Denied. Only approved users or real big titty goths can reshuffle.||No power for you. Earn big titty goths only.
RESHUFFLE_DONE_RESPONSES=Fresh inspection complete. New Bit Titty Goths have been selected.||Reshuffle done. The throne has new favorites.||I reshuffled the lineup. Hope you survive the result.
TIME_RESPONSES=Next BTGO assignment lands at {nextTime} ({relativeTime}).||The next inspection reset is {nextTime} ({relativeTime}).||Roles rotate again at {nextTime} ({relativeTime}).
NO_ONLINE_USERS_RESPONSES=No online simps to inspect right now. Try again later.||Server is too quiet. No online users to assign today.||Nobody online, nobody crowned.
ERROR_RESPONSES=The inspector tripped over a chain. Try again in a moment.||Something broke, simp. Retry in a second.||Technical chaos detected. Try again shortly.
IBTC_TAUNT_RESPONSES={target} step forward from {role}. Your inspection score is still embarrassing.||Attention {target}: another day, another L for your committee.||{target} report in. We are auditing your bad decisions again.
